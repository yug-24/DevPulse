# ── Server ─────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── MongoDB Atlas ───────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/devpulse?retryWrites=true&w=majority

# ── JWT ─────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_64_char_hex_secret_here
JWT_EXPIRES_IN=7d

# ── GitHub OAuth App ────────────────────────────────────────────
# Create at: github.com/settings/developers → New OAuth App
# Homepage URL:        http://localhost:5173
# Callback URL:        http://localhost:5000/api/auth/github/callback
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:5000/api/auth/github/callback

# ── Client URL (for CORS + redirect) ────────────────────────────
CLIENT_URL=http://localhost:5173
